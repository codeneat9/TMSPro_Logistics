# Environment Variables Template - Backend
# Copy this to .env.backend and fill in your values

# ==================== DATABASE ====================
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres

# ==================== REDIS ====================
REDIS_URL=redis://default:password@host.upstash.io:12345

# ==================== FIREBASE ====================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIB...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ==================== APP CONFIGURATION ====================
DEBUG=False
APP_NAME=TMSPro Logistics API
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ==================== OPENSTREETMAP / OSRM ====================
OSRM_API_URL=http://router.project-osrm.org
OPENSTREETMAP_API_URL=https://tile.openstreetmap.org

# ==================== JWT CONFIGURATION ====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==================== DEPLOYMENT ====================
# Render specific
RENDER_EXTERNAL_URL=https://tmspro-api.onrender.com

# ==================== WEBSOCKET ====================
WEBSOCKET_ORIGINS=*
