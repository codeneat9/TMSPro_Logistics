# Environment Variables Template - Mobile Apps
# Create .env files in mobile/customer and mobile/logistics with these values

# ==================== API CONFIGURATION ====================
REACT_APP_API_URL=http://localhost:8000/api

# ==================== FIREBASE CONFIGURATION ====================
REACT_APP_FIREBASE_API_KEY=AIzaSyD...
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abc123def456
REACT_APP_FIREBASE_MEASUREMENT_ID=G-ABC123DEF456

# ==================== MAPS CONFIGURATION ====================
REACT_APP_MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoieW91ciIsImEiOiJjbGs...

# ==================== APP CONFIGURATION ====================
REACT_APP_APP_NAME=TMSPro Customer/Logistics
REACT_APP_ENVIRONMENT=development

# ==================== OPTIONAL ====================
REACT_APP_ANALYTICS_ID=your-google-analytics-id
